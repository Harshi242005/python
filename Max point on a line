import math
from collections import defaultdict

class Solution(object):
    def maxPoints(self, points):
        n = len(points)
        if n <= 2:
            return n
        
        max_pts = 1
        
        for i in range(n):
            slopes = defaultdict(int)
            for j in range(i + 1, n):
                dx = points[j][0] - points[i][0]
                dy = points[j][1] - points[i][1]
                
                # Simplify slope using GCD to avoid floating point issues
                g = math.gcd(dx, dy)
                slope = (dx // g, dy // g)
                
                slopes[slope] += 1
                # Update global max (slopes[slope] + 1 to include anchor point i)
                max_pts = max(max_pts, slopes[slope] + 1)
                
        return max_pts
