class Solution(object):
    def maximalRectangle(self, matrix):
        if not matrix or not matrix[0]:
            return 0
        
        n = len(matrix[0])
        heights = [0] * (n + 1) # Extra 0 for the stack sentinel
        max_area = 0
        
        for row in matrix:
            # Update heights for the current "histogram" base
            for i in range(n):
                heights[i] = heights[i] + 1 if row[i] == '1' else 0
            
            # Monotonic Stack to find max area in current row's histogram
            stack = [-1]
            for i in range(n + 1):
                while stack[-1] != -1 and heights[stack[-1]] >= heights[i]:
                    h = heights[stack.pop()]
                    w = i - stack[-1] - 1
                    max_area = max(max_area, h * w)
                stack.append(i)
                
        return max_area
