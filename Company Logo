from collections import Counter

if __name__ == '__main__':
    s = input().strip()
    
    # 1. Count characters
    counts = Counter(s)
    
    # 2. Sort by count (descending) then by character (ascending)
    # .items() returns (char, count) tuples
    # -x[1] makes the count descending; x[0] makes the character ascending
    sorted_chars = sorted(counts.items(), key=lambda x: (-x[1], x[0]))
    
    # 3. Print the top 3 results
    for char, count in sorted_chars[:3]:
        print(f"{char} {count}")
