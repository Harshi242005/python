class Solution(object):
    def numDistinct(self, s, t):
        n, m = len(s), len(t)
        # dp[j] will store the number of ways to form t[:j]
        dp = [0] * (m + 1)
        
        # Base case: An empty t can be formed by any prefix of s in 1 way
        dp[0] = 1
        
        for char_s in s:
            # Iterate backwards to avoid using the same character multiple times 
            # for different parts of t in the same iteration
            for j in range(m, 0, -1):
                if char_s == t[j-1]:
                    dp[j] += dp[j-1]
                    
        return dp[m]
