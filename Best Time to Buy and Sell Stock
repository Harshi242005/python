class Solution(object):
    def maxProfit(self, prices):
        if not prices:
            return 0
        
        # Initialize variables
        # Using float('inf') for buys to ensure any price is lower
        buy1, buy2 = float('inf'), float('inf')
        sell1, sell2 = 0, 0
        
        for price in prices:
            # First transaction: find min buy price and max profit
            buy1 = min(buy1, price)
            sell1 = max(sell1, price - buy1)
            
            # Second transaction: re-invest the profit from sell1
            # buy2 is the "net cost" (price - previous profit)
            buy2 = min(buy2, price - sell1)
            sell2 = max(sell2, price - buy2)
            
        return sell2
