class Solution(object):
    def maxProfit(self, k, prices):
        if not prices or k == 0:
            return 0
        
        # Optimization: If k is large, it's like having unlimited transactions
        if k >= len(prices) // 2:
            return sum(max(prices[i+1] - prices[i], 0) for i in range(len(prices) - 1))
        
        # buy[i] stores the min cost for the i-th transaction
        # sell[i] stores the max profit for the i-th transaction
        buy = [float('inf')] * (k + 1)
        sell = [0] * (k + 1)
        
        for price in prices:
            for i in range(1, k + 1):
                # Min cost to buy: current price - profit from previous sale
                buy[i] = min(buy[i], price - sell[i-1])
                # Max profit to sell: current price - cost of current buy
                sell[i] = max(sell[i], price - buy[i])
                
        return sell[k]
